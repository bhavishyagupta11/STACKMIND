PORT=5000
MONGODB_URI=mongodb+srv://your_db_user:your_db_password@your-cluster.mongodb.net/stackmind?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
NODE_ENV=development

# Local dev or deployed frontend URLs, comma-separated if needed.
# CLIENT_URL=http://localhost:5173,https://your-frontend.vercel.app

# Optional: force the app to use local file-backed storage instead of MongoDB.
# USE_LOCAL_STORE=true
